generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Role values: COLABORADOR | GESTOR | FINANCEIRO | ADMIN
model Usuario {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  senha        String
  perfil       String   @default("COLABORADOR")
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  reembolsos SolicitacaoDeReembolso[] @relation("UserReimbursements")
  historico  HistoricoDaSolicitacao[]
}

// ReembolsoStatus values: RASCUNHO | ENVIADO | APROVADO | REJEITADO | PAGO | CANCELADO
model SolicitacaoDeReembolso {
  id                    Int      @id @default(autoincrement())
  solicitanteId         Int
  categoriaId           Int
  descricao             String
  valor                 Float
  dataDespesa           DateTime
  status                String   @default("RASCUNHO")
  justificativaRejeicao String?
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  solicitante Usuario                  @relation("UserReimbursements", fields: [solicitanteId], references: [id])
  categoria   Categoria                @relation(fields: [categoriaId], references: [id])
  anexos      Anexo[]
  historico   HistoricoDaSolicitacao[]
}

model Categoria {
  id           Int      @id @default(autoincrement())
  nome         String   @unique
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  reembolsos SolicitacaoDeReembolso[]
}

model Anexo {
  id            Int      @id @default(autoincrement())
  solicitacaoId Int
  nomeArquivo   String
  urlArquivo    String
  tipoArquivo   String
  criadoEm      DateTime @default(now())

  reembolso SolicitacaoDeReembolso @relation(fields: [solicitacaoId], references: [id])
}

// HistoryAction values: CREATED | UPDATED | SUBMITTED | APPROVED | REJECTED | PAID | CANCELED
model HistoricoDaSolicitacao {
  id            Int      @id @default(autoincrement())
  solicitacaoId Int
  usuarioId     Int
  acao          String
  observacao    String?
  criadoEm      DateTime @default(now())

  reembolso SolicitacaoDeReembolso @relation(fields: [solicitacaoId], references: [id])
  usuario   Usuario                @relation(fields: [usuarioId], references: [id])
}
